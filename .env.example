PORT=8787

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Anthropic Claude ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Output controls
AGENT_MAX_TOKENS=4096

# ── Google (Gmail + Calendar) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft 365 ─────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Slack ──────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── IMAP / SMTP (email) ────────────────────────────────────────────────────
# Used by the Python email poller (services/email_poller/main.py)
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASS=
IMAP_PORT=993
IMAP_MAILBOX=INBOX
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# ── Email poller behaviour ─────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=60          # seconds between IMAP checks
EMAIL_AUTO_TRIAGE=false         # set to "true" to auto-start a Claude triage session per email
HYPERION_URL=http://127.0.0.1:8787   # where the poller POSTs new emails

# ── Vector memory service ──────────────────────────────────────────────────
# Leave blank to use built-in keyword search.
# Set to the URL of the Python vector service (services/vector_memory/).
VECTOR_MEMORY_URL=
# VECTOR_MEMORY_URL=http://127.0.0.1:8788

# ── Vector service internals (set in services/vector_memory/.env if needed)
EMBED_MODEL=all-MiniLM-L6-v2
CHROMA_PATH=./data/chroma
VECTOR_PORT=8788
